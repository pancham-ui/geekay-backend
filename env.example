# ================================
# GEE KAY AGENCIES — ENVIRONMENT
# ================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/geekay_db
# Production: mongodb+srv://<user>:<password>@cluster.mongodb.net/geekay_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Nodemailer — Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Gee Kay Agencies <noreply@geekayagencies.com>
ADMIN_EMAIL=arorasc077@gmail.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Frontend origin (for CORS)
CLIENT_URL=http://localhost:3000

# Admin seed credentials (used only for initial setup — change immediately)
SEED_ADMIN_EMAIL=admin@geekayagencies.com
SEED_ADMIN_PASSWORD=ChangeMe@123!
